# Copy to .env and fill in (or set these as App Service application settings).
# Everything below is optional — the app runs without any of it.

# Where channels, message logs, and voice clips are stored.
# Local default: ./data   •   Azure App Service: /home/data
DATA_DIR=./data

# Port to listen on (App Service injects this automatically).
PORT=3000

# Voice-clip transcription via Azure AI Speech. Leave unset to disable transcription
# (clips still post and play, just without transcripts).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Optional: comma-separated candidate locales for transcription (default en-US).
AZURE_SPEECH_LOCALES=en-US
